PROJECT_NAME=healthcare-bigdata-project

OPENFDA_API_URL=https://api.fda.gov/drug/event.json
OPENFDA_SEARCH_QUERY=patient.drug.medicinalproduct:*
OPENFDA_PAGE_SIZE=100
OPENFDA_MAX_PAGES=20
OPENFDA_SLEEP_SECONDS=3
OPENFDA_REQUEST_TIMEOUT_SECONDS=30
OPENFDA_MAX_RETRIES=5
OPENFDA_SOURCE_NAME=openFDA drug event API

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=healthcare_raw
KAFKA_CLIENT_ID=healthcare_api_producer
KAFKA_AUTO_CREATE_TOPIC=false
KAFKA_TOPIC_PARTITIONS=1
KAFKA_TOPIC_REPLICATION_FACTOR=1

HDFS_URI=hdfs://namenode:8020
HDFS_RAW_PATH=/healthcare/raw
HDFS_PROCESSED_PATH=/healthcare/processed
HDFS_MODELS_PATH=/healthcare/models
HDFS_REPORTING_PATH=/healthcare/reporting
HDFS_CHECKPOINT_PATH=/healthcare/checkpoints

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=healthcare_dw
POSTGRES_USER=healthcare
POSTGRES_PASSWORD=healthcare123
POSTGRES_JDBC_URL=jdbc:postgresql://postgres:5432/healthcare_dw

SPARK_MASTER_URL=spark://spark-master:7077
SPARK_APP_NAME=healthcare-analytics
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
SPARK_JARS_PACKAGES=org.postgresql:postgresql:42.7.3
SPARK_MASTER_WEB_PORT=18080
SPARK_WORKER_WEB_PORT=18081

METABASE_SITE_URL=http://localhost:3000
METABASE_PORT=3000

DOCKER_PROJECT_NAME=healthcare_bigdata
